# ── Django ─────────────────────────────────────────────────────────────────────
SECRET_KEY=your_secret_key_here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# ── Admin superuser (created by entrypoint) ────────────────────────────────────
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=changeme123!

# ── Demo data seeding (LOCAL ONLY) ─────────────────────────────────────────────
# When "true", the docker-compose web service runs `manage.py seed_data --force`
# on startup. This is wired into docker-compose only — the production Dockerfile
# never seeds. The command is idempotent, so it is safe to leave on locally.
SEED_DEMO_DATA=false

# ── Database (PostGIS) ─────────────────────────────────────────────────────────
# Use DATABASE_URL for Railway / cloud deployments (takes priority over individual vars).
# DATABASE_URL=postgis://user:password@host:5432/dbname

DB_NAME=snapfix
DB_USER=snapfix
DB_PASSWORD=snapfix123
DB_HOST=localhost
DB_PORT=5432

# ── Redis (Celery broker + Constance backend) ──────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# ── AI Document Validation ─────────────────────────────────────────────────────
# The active provider is controlled at runtime via Django Admin → Constance.
# Set whichever keys correspond to the provider(s) you want to use.
# If AI_VALIDATION_PROVIDER is "all", the pipeline tries each in order until one succeeds.
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
GROQ_API_KEY=gsk_your-key-here
GEMINI_API_KEY=your-gemini-key-here

# ── Firebase / FCM (push notifications) ────────────────────────────────────────
# Path to your Firebase service account JSON file (for local dev).
# In production, set the JSON content directly via GOOGLE_APPLICATION_CREDENTIALS_JSON
# or mount the file and point this variable to it.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/firebase-service-account.json
